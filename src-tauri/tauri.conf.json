{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "DGCoder",
	"version": "0.1.0",
	"identifier": "com.dgcoder.pi",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://127.0.0.1:5182",
		"beforeDevCommand": "pnpm setup:imagemagick && pnpm dev",
		"beforeBuildCommand": "pnpm setup:imagemagick && pnpm build"
	},
	"app": {
		"windows": [
			{
				"title": "DGCoder",
				"width": 1600,
				"height": 1000,
				"minWidth": 1280,
				"minHeight": 800,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
